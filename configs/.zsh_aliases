# ==========================================
# Zsh Aliases
# ==========================================

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# List files
alias ll='eza -la --icons'
alias ls='eza --icons'
alias la='eza -a --icons'
alias lt='eza -T --icons'
alias lta='eza -T -a --icons'

# Git
alias gs='git status'
alias ga='git add'
alias gaa='git add -A'
alias gc='git commit -m'
alias gca='git commit --amend'
alias gp='git push'
alias gpl='git pull'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
alias gl='git log --oneline --graph --decorate'
alias glog='git log --oneline --graph --decorate --all'
alias gf='git fetch'
alias gm='git merge'
alias gr='git remote -v'
alias gtags='git tag -l'

# Docker
alias dps='docker ps'
alias dpsa='docker ps -a'
alias di='docker images'
alias dl='docker logs'
alias dexec='docker exec -it'
alias dstop='docker stop'
alias drm='docker rm'
alias drmi='docker rmi'
alias dcb='docker compose build'
alias dcu='docker compose up -d'
alias dcd='docker compose down'
alias dcl='docker compose logs -f'

# Python
alias py='python3'
alias pip='pip3'
alias venv='python3 -m venv .venv && source .venv/bin/activate'

# Node
alias nls='nvm ls'
alias nuse='nvm use'
alias ninst='nvm install'

# Java / SDKMAN
alias jls='sdk list java'
alias juse='sdk use java'
alias jinst='sdk install java'

# System
alias htop='btop'
alias cat='bat --paging=never'
alias grep='rg'
alias find='fd'
alias df='df -h'
alias du='du -h'
alias mkdir='mkdir -p'

# Git lazygit
alias lg='lazygit'

# Quick edit
alias vc='vim ~/.zshrc'
alias va='vim ~/.zsh_aliases'
alias sc='source ~/.zshrc'

# Extract archives
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1" ;;
            *.tar.gz)    tar xzf "$1" ;;
            *.bz2)       bunzip2 "$1" ;;
            *.rar)       unrar x "$1" ;;
            *.gz)        gunzip "$1" ;;
            *.tar)       tar xf "$1" ;;
            *.tbz2)      tar xjf "$1" ;;
            *.tgz)       tar xzf "$1" ;;
            *.zip)       unzip "$1" ;;
            *.Z)         uncompress "$1" ;;
            *.7z)        7z x "$1" ;;
            *)           echo "'$1' cannot be extracted" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}
