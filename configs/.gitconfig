[user]
    name = Your Name
    email = your@email.com

[core]
    editor = vim
    autocrlf = input
    excludesfile = ~/.gitignore_global

[init]
    defaultBranch = main

[push]
    default = simple

[pull]
    rebase = true

[merge]
    conflictstyle = diff3

[diff]
    tool = vimdiff

[alias]
    st = status
    co = checkout
    br = branch
    lg = log --oneline --graph --decorate
    last = log -1 HEAD
    unstage = reset HEAD --
    amend = commit --amend -C HEAD
